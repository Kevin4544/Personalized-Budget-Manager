import tkinter as tk
from tkinter import messagebox
from tkinter import ttk
from collections import defaultdict
from datetime import datetime
import json
import os

import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg


DATA_FILE = "finance_data.json"

records = []
monthly_income = 0.0


def save_data():
    data = {
        "records": records,
        "monthly_income": monthly_income
    }

    with open(DATA_FILE, "w") as file:
        json.dump(data, file, indent=4)


def load_data():
    global records, monthly_income

    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, "r") as file:
            data = json.load(file)
            records = data.get("records", [])
            monthly_income = data.get("monthly_income", 0.0)

            income_entry.delete(0, tk.END)
            income_entry.insert(0, str(monthly_income))


def get_selected_category():
    choice = category_var.get()

    if choice == "Other":
        return other_category_entry.get().strip()

    return choice


def add_transaction():
    global monthly_income

    category = get_selected_category()
    amount_text = amount_entry.get().strip()
    date_text = date_entry.get().strip()
    trans_type = type_var.get()

    if category == "":
        messagebox.showerror("Input Error", "Please enter a category.")
        return

    if amount_text == "":
        messagebox.showerror("Input Error", "Please enter an amount.")
        return

    if date_text == "":
        messagebox.showerror("Input Error", "Please enter a date.")
        return

    try:
        amount = float(amount_text)
        if amount < 0:
            messagebox.showerror("Input Error", "Amount must be 0 or greater.")
            return
    except ValueError:
        messagebox.showerror("Input Error", "Amount must be a valid number.")
        return

    try:
        datetime.strptime(date_text, "%Y-%m-%d")
    except ValueError:
        messagebox.showerror("Input Error", "Date must be in YYYY-MM-DD format.")
        return

    record = {
        "type": trans_type,
        "category": category,
        "amount": amount,
        "date": date_text
    }

    records.append(record)

    save_data()
    show_records()
    update_summary()
    update_budget_method_display()
    update_category_chart()
    update_balance_chart()
    clear_inputs()


def clear_inputs():
    amount_entry.delete(0, tk.END)
    date_entry.delete(0, tk.END)
    other_category_entry.delete(0, tk.END)
    category_var.set("Groceries")
    type_var.set("Expense")


def show_records():
    transaction_listbox.delete(0, tk.END)

    for index, record in enumerate(records, start=1):
        line = f"{index}. {record['date']} | {record['type']} | {record['category']} | ${record['amount']:.2f}"
        transaction_listbox.insert(tk.END, line)


def delete_selected():
    selected = transaction_listbox.curselection()

    if not selected:
        messagebox.showerror("Selection Error", "Please select a transaction to delete.")
        return

    index = selected[0]
    del records[index]

    save_data()
    show_records()
    update_summary()
    update_budget_method_display()
    update_category_chart()
    update_balance_chart()


def set_income():
    global monthly_income

    income_text = income_entry.get().strip()

    if income_text == "":
        messagebox.showerror("Input Error", "Please enter your monthly income.")
        return

    try:
        monthly_income = float(income_text)
        if monthly_income < 0:
            messagebox.showerror("Input Error", "Income must be 0 or greater.")
            return
    except ValueError:
        messagebox.showerror("Input Error", "Income must be a valid number.")
        return

    save_data()
    update_summary()
    update_budget_method_display()
    update_balance_chart()


def get_total_expenses():
    total = 0.0

    for record in records:
        if record["type"] == "Expense":
            total += record["amount"]

    return total


def get_total_income_records():
    total = 0.0

    for record in records:
        if record["type"] == "Income":
            total += record["amount"]

    return total


def update_summary():
    entered_income = monthly_income
    added_income = get_total_income_records()
    total_expenses = get_total_expenses()

    total_income = entered_income + added_income
    balance = total_income - total_expenses

    summary_label.config(
        text=(
            f"Monthly Income: ${entered_income:.2f}    "
            f"Added Income: ${added_income:.2f}    "
            f"Expenses: ${total_expenses:.2f}    "
            f"Balance: ${balance:.2f}"
        )
    )


def fifty_thirty_twenty(income):
    needs = income * 0.50
    wants = income * 0.30
    savings = income * 0.20

    return (
        f"50/30/20 Rule\n"
        f"Needs: ${needs:.2f}\n"
        f"Wants: ${wants:.2f}\n"
        f"Savings/Debt: ${savings:.2f}"
    )


def zero_based(income):
    return (
        f"Zero-Based Budget\n"
        f"Income: ${income:.2f}\n"
        f"Give every dollar a job until you reach $0 left unassigned."
    )


def envelope(income):
    return (
        f"Envelope Budget\n"
        f"Income: ${income:.2f}\n"
        f"Split money into categories like rent, groceries, and entertainment."
    )


def seventy_twenty_ten(income):
    living = income * 0.70
    savings = income * 0.20
    debt_or_giving = income * 0.10

    return (
        f"70/20/10 Rule\n"
        f"Living: ${living:.2f}\n"
        f"Savings: ${savings:.2f}\n"
        f"Debt/Giving: ${debt_or_giving:.2f}"
    )


def update_budget_method_display():
    income = monthly_income + get_total_income_records()
    method = budget_method_var.get()

    if income <= 0:
        budget_result_label.config(text="Enter income to view a budgeting method.")
        return

    if method == "50/30/20 Rule":
        result = fifty_thirty_twenty(income)
    elif method == "Zero-Based":
        result = zero_based(income)
    elif method == "Envelope":
        result = envelope(income)
    elif method == "70/20/10 Rule":
        result = seventy_twenty_ten(income)
    else:
        result = "Choose a budgeting method."

    budget_result_label.config(text=result)


def update_category_chart():
    category_totals = defaultdict(float)

    for record in records:
        if record["type"] == "Expense":
            category_totals[record["category"]] += record["amount"]

    categories = list(category_totals.keys())
    amounts = list(category_totals.values())

    category_chart.clear()

    if categories:
        category_chart.bar(categories, amounts)
        category_chart.set_title("Spending by Category")
        category_chart.set_xlabel("Category")
        category_chart.set_ylabel("Amount ($)")
        category_chart.tick_params(axis="x", rotation=25)
    else:
        category_chart.set_title("Spending by Category")
        category_chart.text(0.5, 0.5, "No expense data yet", ha="center", va="center")

    category_figure.tight_layout()
    category_canvas.draw()


def update_balance_chart():
    entered_income = monthly_income
    added_income = get_total_income_records()
    total_expenses = get_total_expenses()
    total_income = entered_income + added_income
    balance = total_income - total_expenses

    balance_chart.clear()

    labels = ["Income", "Expenses", "Balance"]
    values = [total_income, total_expenses, max(balance, 0)]

    if total_income > 0 or total_expenses > 0:
        balance_chart.pie(values, labels=labels, autopct="%1.1f%%", startangle=90)
        balance_chart.set_title("Income Breakdown")
    else:
        balance_chart.set_title("Income Breakdown")
        balance_chart.text(0.5, 0.5, "No data yet", ha="center", va="center")

    balance_figure.tight_layout()
    balance_canvas.draw()


window = tk.Tk()
window.title("Personal Finance Tracker")
window.geometry("1600x900")
window.configure(bg="#e9ecef")


main_frame = tk.Frame(window, bg="#e9ecef")
main_frame.pack(fill="both", expand=True, padx=15, pady=15)

left_frame = tk.Frame(main_frame, bg="white", bd=1, relief="solid", padx=15, pady=15)
left_frame.pack(side="left", fill="y", padx=(0, 10))

middle_frame = tk.Frame(main_frame, bg="white", bd=1, relief="solid", padx=15, pady=15, width=420)
middle_frame.pack(side="left", fill="y", padx=(0, 10))
middle_frame.pack_propagate(False)

right_frame = tk.Frame(main_frame, bg="white", bd=1, relief="solid", padx=15, pady=15)
right_frame.pack(side="right", fill="both", expand=True)


label_style = {"bg": "white", "fg": "#222222"}
button_style = {
    "bg": "#dfe6ee",
    "fg": "#222222",
    "activebackground": "#cfd8e3",
    "activeforeground": "#111111"
}
entry_style = {
    "bg": "white",
    "fg": "#222222",
    "insertbackground": "#222222"
}


type_var = tk.StringVar(value="Expense")
category_var = tk.StringVar(value="Groceries")
budget_method_var = tk.StringVar(value="50/30/20 Rule")


tk.Label(left_frame, text="Finance Input", font=("Arial", 16, "bold"), **label_style).pack(pady=10)

tk.Label(left_frame, text="Monthly Income", **label_style).pack(anchor="w")
income_entry = tk.Entry(left_frame, width=25, **entry_style)
income_entry.pack(pady=5)

tk.Button(left_frame, text="Set Income", command=set_income, width=20, **button_style).pack(pady=8)

tk.Label(left_frame, text="Date (YYYY-MM-DD)", **label_style).pack(anchor="w")
date_entry = tk.Entry(left_frame, width=25, **entry_style)
date_entry.pack(pady=5)
date_entry.insert(0, datetime.now().strftime("%Y-%m-%d"))

tk.Label(left_frame, text="Type", **label_style).pack(anchor="w")
type_menu = tk.OptionMenu(left_frame, type_var, "Expense", "Income")
type_menu.pack(pady=5, fill="x")

tk.Label(left_frame, text="Category", **label_style).pack(anchor="w")
category_menu = tk.OptionMenu(
    left_frame,
    category_var,
    "Groceries",
    "Rent",
    "Utilities",
    "Entertainment",
    "Other"
)
category_menu.pack(pady=5, fill="x")

tk.Label(left_frame, text="Other Category", **label_style).pack(anchor="w")
other_category_entry = tk.Entry(left_frame, width=25, **entry_style)
other_category_entry.pack(pady=5)

tk.Label(left_frame, text="Amount", **label_style).pack(anchor="w")
amount_entry = tk.Entry(left_frame, width=25, **entry_style)
amount_entry.pack(pady=5)

tk.Button(left_frame, text="Add Transaction", command=add_transaction, width=20, **button_style).pack(pady=10)
tk.Button(left_frame, text="Delete Selected", command=delete_selected, width=20, **button_style).pack(pady=5)

tk.Label(left_frame, text="Budgeting Method", font=("Arial", 12, "bold"), **label_style).pack(pady=(20, 5))
budget_menu = tk.OptionMenu(
    left_frame,
    budget_method_var,
    "50/30/20 Rule",
    "Zero-Based",
    "Envelope",
    "70/20/10 Rule",
    command=lambda x: update_budget_method_display()
)
budget_menu.pack(pady=5, fill="x")

budget_result_label = tk.Label(
    left_frame,
    text="Enter income to view a budgeting method.",
    justify="left",
    wraplength=250,
    **label_style
)
budget_result_label.pack(pady=10, anchor="w")


tk.Label(middle_frame, text="Transactions", font=("Arial", 16, "bold"), **label_style).pack(pady=10)

transaction_listbox = tk.Listbox(middle_frame, width=50, height=35)
transaction_listbox.pack(fill="both", expand=True, pady=10)

summary_label = tk.Label(
    middle_frame,
    text="Monthly Income: $0.00    Added Income: $0.00    Expenses: $0.00    Balance: $0.00",
    justify="left",
    wraplength=380,
    **label_style
)
summary_label.pack(pady=10, anchor="w")


charts_top_frame = tk.Frame(right_frame, bg="white")
charts_top_frame.pack(fill="both", expand=True)

charts_bottom_frame = tk.Frame(right_frame, bg="white")
charts_bottom_frame.pack(fill="both", expand=True)

category_figure = plt.Figure(figsize=(7, 4), dpi=100)
category_chart = category_figure.add_subplot(111)
category_canvas = FigureCanvasTkAgg(category_figure, master=charts_top_frame)
category_canvas.get_tk_widget().pack(fill="both", expand=True)

balance_figure = plt.Figure(figsize=(7, 4), dpi=100)
balance_chart = balance_figure.add_subplot(111)
balance_canvas = FigureCanvasTkAgg(balance_figure, master=charts_bottom_frame)
balance_canvas.get_tk_widget().pack(fill="both", expand=True)


load_data()
show_records()
update_summary()
update_budget_method_display()
update_category_chart()
update_balance_chart()

window.mainloop()
