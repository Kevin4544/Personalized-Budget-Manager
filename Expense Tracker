import tkinter as tk
from tkinter import messagebox
from collections import defaultdict
from datetime import datetime
import json
import os

import matplotlib.pyplot as plt
from matplotlib.figure import Figure
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg

# File where all budget data will be saved
DATA_FILE = "budget_data.json"

# List to store all transactions
records = []


# Save transactions and goal to a file
def save_data():
    data = {
        "records": records,
        "goal": goal_var.get()
    }

    with open(DATA_FILE, "w") as file:
        json.dump(data, file, indent=4)


# Load transactions and goal from the file if it exists
def load_data():
    global records

    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, "r") as file:
            data = json.load(file)
            records = data.get("records", [])
            goal_var.set(data.get("goal", 0.0))


# Add a new transaction
def add_transaction():
    entry_type = type_var.get()
    group = category_entry.get().strip()
    amount_text = amount_entry.get().strip()
    note_text = note_entry.get().strip()
    date_text = date_entry.get().strip()

    # Make sure required boxes are filled in
    if group == "" or amount_text == "" or date_text == "":
        messagebox.showerror("Input Error", "Please fill in date, category, and amount.")
        return

    # Check if amount is a valid number
    try:
        amount = float(amount_text)
        if amount < 0:
            messagebox.showerror("Input Error", "Amount must be 0 or greater.")
            return
    except ValueError:
        messagebox.showerror("Input Error", "Amount must be a number.")
        return

    # Check if date is in the correct format
    try:
        datetime.strptime(date_text, "%Y-%m-%d")
    except ValueError:
        messagebox.showerror("Input Error", "Date must be in YYYY-MM-DD format.")
        return

    # Create one transaction record
    record = {
        "date": date_text,
        "type": entry_type,
        "category": group,
        "amount": amount,
        "note": note_text
    }

    # Add the new record to the list
    records.append(record)

    # Refresh everything on the screen
    save_data()
    show_records()
    update_summary()
    update_goal_progress()
    update_month_list()
    update_savings_chart()
    update_category_chart()

    # Clear the input boxes
    date_entry.delete(0, tk.END)
    category_entry.delete(0, tk.END)
    amount_entry.delete(0, tk.END)
    note_entry.delete(0, tk.END)


# Show all transactions in the listbox
def show_records():
    transaction_listbox.delete(0, tk.END)

    for i, item in enumerate(records, start=1):
        line = f"{i}. {item['date']} | {item['type']} | {item['category']} | ${item['amount']:.2f}"
        transaction_listbox.insert(tk.END, line)


# Update income, expense, and balance totals
def update_summary():
    total_income = 0
    total_expense = 0

    for item in records:
        if item["type"] == "Income":
            total_income += item["amount"]
        else:
            total_expense += item["amount"]

    balance = total_income - total_expense

    summary_label.config(
        text=f"Income: ${total_income:.2f}    Expenses: ${total_expense:.2f}    Balance: ${balance:.2f}"
    )


# Delete the selected transaction
def delete_transaction():
    selected = transaction_listbox.curselection()

    if not selected:
        messagebox.showerror("Selection Error", "Please select a transaction to delete.")
        return

    index = selected[0]
    records.pop(index)

    # Refresh everything after deleting
    save_data()
    show_records()
    update_summary()
    update_goal_progress()
    update_month_list()
    update_savings_chart()
    update_category_chart()


# Set the savings goal
def set_goal():
    goal_text = goal_entry.get().strip()

    if goal_text == "":
        messagebox.showerror("Input Error", "Please enter a savings goal.")
        return

    # Check if goal is a valid number
    try:
        goal_amount = float(goal_text)
        if goal_amount <= 0:
            messagebox.showerror("Input Error", "Goal must be greater than 0.")
            return
    except ValueError:
        messagebox.showerror("Input Error", "Goal must be a number.")
        return

    goal_var.set(goal_amount)
    save_data()
    update_goal_progress()


# Update the goal progress text
def update_goal_progress():
    total_income = 0
    total_expense = 0

    for item in records:
        if item["type"] == "Income":
            total_income += item["amount"]
        else:
            total_expense += item["amount"]

    balance = total_income - total_expense
    goal_amount = goal_var.get()

    if goal_amount > 0:
        percent = (balance / goal_amount) * 100

        # Keep percent between 0 and 100
        if percent < 0:
            percent = 0
        if percent > 100:
            percent = 100

        goal_label.config(
            text=f"Goal: ${goal_amount:.2f}\nSaved: ${balance:.2f}\nProgress: {percent:.1f}%"
        )
    else:
        goal_label.config(text="No savings goal set.")


# Get the year and month part from a date
def get_month_from_date(date_text):
    return date_text[:7]


# Update the month drop-down list
def update_month_list():
    months = sorted({get_month_from_date(item["date"]) for item in records})

    month_menu["menu"].delete(0, "end")

    if not months:
        selected_month.set("")
        month_menu["menu"].add_command(label="", command=tk._setit(selected_month, ""))
        return

    if selected_month.get() not in months:
        selected_month.set(months[0])

    for month in months:
        month_menu["menu"].add_command(
            label=month,
            command=lambda value=month: change_selected_month(value)
        )


# Change the selected month and update the category chart
def change_selected_month(month):
    selected_month.set(month)
    update_category_chart()


# Add simple chart styling
def style_axis(chart):
    chart.grid(True, axis="y", linestyle="--", alpha=0.4)
    chart.set_facecolor("#f8f9fa")
    chart.spines["top"].set_visible(False)
    chart.spines["right"].set_visible(False)
    chart.spines["left"].set_color("#cccccc")
    chart.spines["bottom"].set_color("#cccccc")
    chart.title.set_fontsize(14)
    chart.xaxis.label.set_fontsize(11)
    chart.yaxis.label.set_fontsize(11)


# Update the savings by month chart
def update_savings_chart():
    total_income = 0
    total_expense = 0

    # Add all income and expense values
    for item in records:
        if item["type"] == "Income":
            total_income += item["amount"]
        else:
            total_expense += item["amount"]

    # Savings is income minus expense
    total_savings = total_income - total_expense

    savings_chart.clear()

    # Only make the chart if there is income
    if total_income > 0:
        labels = ["Expenses", "Savings"]
        values = [total_expense, max(total_savings, 0)]

        # Remove empty parts from the chart
        chart_data = [(label, value) for label, value in zip(labels, values) if value > 0]

        if chart_data:
            labels = [item[0] for item in chart_data]
            values = [item[1] for item in chart_data]

            savings_chart.pie(
                values,
                labels=labels,
                autopct="%1.1f%%",
                startangle=90
            )
            savings_chart.set_title("Income Breakdown", pad=12)
        else:
            savings_chart.set_title("Income Breakdown", pad=12)
            savings_chart.text(0.5, 0.5, "No data to show", ha="center", va="center")
    else:
        savings_chart.set_title("Income Breakdown", pad=12)
        savings_chart.text(0.5, 0.5, "No income data yet", ha="center", va="center")

    savings_figure.tight_layout()
    savings_canvas.draw()

# Update the spending by category chart
def update_category_chart():
    month = selected_month.get()
    category_totals = defaultdict(float)

    if month != "":
        for item in records:
            if item["type"] == "Expense" and get_month_from_date(item["date"]) == month:
                category_totals[item["category"]] += item["amount"]

    sorted_data = sorted(category_totals.items(), key=lambda item: item[1], reverse=True)
    categories = [item[0] for item in sorted_data]
    amounts = [item[1] for item in sorted_data]

    category_chart.clear()

    if categories:
        category_chart.barh(categories, amounts, color="#5B8DEF", edgecolor="black", linewidth=0.8)
        category_chart.set_title(f"Spending by Category for {month}", pad=12)
        category_chart.set_xlabel("Amount ($)")
        category_chart.set_ylabel("Category")
        category_chart.tick_params(axis="x", colors="#222222")
        category_chart.tick_params(axis="y", colors="#222222")
        style_axis(category_chart)
    else:
        category_chart.set_title("Spending by Category", pad=12)
        style_axis(category_chart)

    category_figure.tight_layout()
    category_canvas.draw()


