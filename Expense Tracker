    def validate_month_key(self):
        month_key = self.month_var.get().strip()
        try:
            datetime.strptime(month_key + "-01", DATE_FMT)
        except ValueError:
            messagebox.showerror("Invalid Month", "Use YYYY-MM for the working month.")
            return None
        return month_key

    def get_monthly_income(self):
        try:
            return float(self.db.get_setting("monthly_income", "0"))
        except ValueError:
            return 0.0

    def get_custom_percent(self):
        try:
            return float(self.db.get_setting("custom_savings_percent", "20"))
        except ValueError:
            return 20.0

    def refresh_categories(self):
        categories = self.db.get_categories()
        self.category_menu["values"] = categories
        plan_categories = [c for c in categories if c != "Savings"] + ["Savings"]
        self.plan_category_menu["values"] = plan_categories

        if self.category_var.get() not in categories:
            self.category_var.set("Groceries" if "Groceries" in categories else categories[0])
        if self.plan_category_var.get() not in plan_categories:
            self.plan_category_var.set("Rent" if "Rent" in plan_categories else plan_categories[0])

        self.sync_type_category()

    def sync_type_category(self):
        trans_type = self.type_var.get()
        if trans_type == "Income":
            self.category_var.set("Income")
            self.category_menu.configure(state="disabled")
        elif trans_type == "Savings":
            if "Savings" in self.db.get_categories():
                self.category_var.set("Savings")
            self.category_menu.configure(state="readonly")
        else:
            if self.category_var.get() in ("Income", "Savings"):
                self.category_var.set("Groceries")
            self.category_menu.configure(state="readonly")

    def save_income(self):
        try:
            value = float(self.income_var.get().strip())
            if value < 0:
                raise ValueError
        except ValueError:
            messagebox.showerror("Input Error", "Monthly income must be 0 or greater.")
            return
        self.db.set_setting("monthly_income", value)
        self.refresh_all()

    def save_custom_percent(self):
        try:
            value = float(self.custom_percent_var.get().strip())
            if value < 0 or value > 100:
                raise ValueError
        except ValueError:
            messagebox.showerror("Input Error", "Custom savings percent must be between 0 and 100.")
            return
        self.db.set_setting("custom_savings_percent", value)
        self.refresh_all()

    def on_method_change(self):
        self.db.set_setting("budget_method", self.method_var.get())
        self.update_custom_visibility()
        self.refresh_all()

    def update_custom_visibility(self):
        if self.method_var.get() == "Custom Savings":
            self.custom_frame.pack(fill="x", pady=(8, 0))
        else:
            self.custom_frame.pack_forget()

    def add_category(self):
        name = self.new_category_entry.get().strip()
        if not name:
            messagebox.showerror("Input Error", "Enter a category name.")
            return
        if name.lower() == "income":
            messagebox.showerror("Input Error", "Income is reserved for income entries.")
            return
        self.db.add_category(name)
        self.new_category_entry.delete(0, tk.END)
        self.refresh_categories()

    def add_transaction(self):
        month_key = self.validate_month_key()
        if not month_key:
            return

        date_text = self.date_entry.get().strip()
        trans_type = self.type_var.get()
        category = self.category_var.get().strip()
        amount_text = self.amount_entry.get().strip()

        try:
            parsed = datetime.strptime(date_text, DATE_FMT)
        except ValueError:
            messagebox.showerror("Input Error", "Date must use YYYY-MM-DD.")
            return

        if parsed.strftime("%Y-%m") != month_key:
            messagebox.showerror("Month Mismatch", "Transaction date must match the working month.")
            return

        if trans_type == "Income":
            category = "Income"
        elif trans_type == "Savings":
            category = "Savings"

        try:
            amount = float(amount_text)
            if amount < 0:
                raise ValueError
        except ValueError:
            messagebox.showerror("Input Error", "Amount must be a valid number 0 or greater.")
            return

        self.db.add_transaction(date_text, trans_type, category, amount)
        self.amount_entry.delete(0, tk.END)
        self.refresh_all()

    def delete_selected_transaction(self):
        selected = self.tree.selection()
        if not selected:
            messagebox.showerror("Selection Error", "Select a transaction first.")
            return
        tx_id = self.tree.item(selected[0], "values")[0]
        self.db.delete_transaction(int(tx_id))
        self.refresh_all()

    def set_plan_amount(self):
        month_key = self.validate_month_key()
        if not month_key:
            return
        category = self.plan_category_var.get().strip()
        try:
            amount = float(self.plan_amount_var.get().strip())
            if amount < 0:
                raise ValueError
        except ValueError:
            messagebox.showerror("Input Error", "Plan amount must be 0 or greater.")
            return

        allocations = self.db.get_allocations(month_key)
        allocations[category] = amount
        self.db.save_allocations(month_key, allocations)
        self.plan_amount_var.set("")
        self.refresh_all()

    def clear_month_plan(self):
        month_key = self.validate_month_key()
        if not month_key:
            return
        self.db.save_allocations(month_key, {})
        self.refresh_all()

    def get_budget_model_data(self, month_key):
        income = self.get_monthly_income() + self.db.get_month_totals(month_key)["Income"]
        method = self.method_var.get()
        if income <= 0:
            return {}

        if method == "50/30/20 Rule":
            return {"Needs": income * 0.50, "Wants": income * 0.30, "Savings": income * 0.20}
        if method == "70/20/10 Rule":
            return {"Living": income * 0.70, "Savings": income * 0.20, "Debt/Giving": income * 0.10}
        if method == "Custom Savings":
            percent = self.get_custom_percent() / 100.0
            savings = income * percent
            return {"Spending": income - savings, "Savings": savings}
        if method == "Zero-Based":
            return self.db.get_allocations(month_key)
        return {}

    def get_summary_numbers(self, month_key):
        totals = self.db.get_month_totals(month_key)
        entered_income = self.get_monthly_income()
        added_income = totals["Income"]
        total_income = entered_income + added_income
        expenses = totals["Expense"]
        savings_entries = totals["Savings"]
        balance = total_income - expenses - savings_entries
        return {
            "entered_income": entered_income,
            "added_income": added_income,
            "total_income": total_income,
            "expenses": expenses,
            "savings_entries": savings_entries,
            "balance": balance,
        }

    def update_summary(self, month_key):
        nums = self.get_summary_numbers(month_key)
        self.summary_label.config(
            text=(
                f"Month: {month_key}    Monthly Income: ${nums['entered_income']:.2f}    Added Income: ${nums['added_income']:.2f}\n"
                f"Total Income: ${nums['total_income']:.2f}    Expenses: ${nums['expenses']:.2f}    Savings Entries: ${nums['savings_entries']:.2f}    Balance: ${nums['balance']:.2f}"
            )
        )

        method = self.method_var.get()
        model_data = self.get_budget_model_data(month_key)
        if method == "Zero-Based":
            assigned = sum(model_data.values())
            income = nums["total_income"]
            difference = income - assigned
            progress = 0 if income <= 0 else min((assigned / income) * 100, 100)
            status_text = (
                f"Assigned: ${assigned:.2f} of ${income:.2f}    Unassigned: ${max(difference, 0):.2f}    Over Budget: ${abs(min(difference, 0)):.2f}"
            )
        else:
            target = model_data.get("Savings", 0.0)
            actual = nums["savings_entries"]
            progress = 0 if target <= 0 else min((actual / target) * 100, 100)
            status_text = f"Savings Target: ${target:.2f}    Actual Savings Entries: ${actual:.2f}    Progress: {progress:.1f}%"

        self.progress_label.config(text=status_text)
        self.progress_container.update_idletasks()
        width = self.progress_container.winfo_width()
        self.progress_fill.config(width=int(width * (progress / 100.0)))

    def update_transactions_table(self, month_key):
        for item in self.tree.get_children():
            self.tree.delete(item)
        for row in self.db.get_transactions_for_month(month_key):
            self.tree.insert(
                "",
                "end",
                values=(row["id"], row["date"], row["type"], row["category"], f"${float(row['amount']):.2f}"),
            )

    def update_model_chart(self, month_key):
        self.model_chart.clear()
        nums = self.get_summary_numbers(month_key)
        income = nums["total_income"]
        method = self.method_var.get()
        data = self.get_budget_model_data(month_key)

        if income <= 0:
            self.model_chart.set_title("Budget Model Overview")
            self.model_chart.text(0.5, 0.5, "Add income for this month to view budget data", ha="center", va="center")
            self.model_figure.tight_layout()
            self.model_canvas.draw()
            return

        if method == "Zero-Based":
            self.model_chart.set_title("Zero-Based Monthly Plan")
            left = 0
            if data:
                for category, value in sorted(data.items(), key=lambda item: item[1], reverse=True):
                    self.model_chart.barh(["Income Plan"], [value], left=left, label=category)
                    left += value

            difference = income - sum(data.values())
            if difference > 0:
                self.model_chart.barh(["Income Plan"], [difference], left=left, label="Unassigned")
            elif difference < 0:
                self.model_chart.barh(["Over Budget"], [abs(difference)], left=0, label="Over Budget")

            self.model_chart.set_xlabel("Amount ($)")
            self.model_chart.legend(loc="upper center", bbox_to_anchor=(0.5, -0.12), ncol=3, fontsize=8)
            self.model_chart.text(income, 0, f"  Total Income ${income:.2f}", va="center")
        else:
            labels = list(data.keys())
            values = list(data.values())
            bars = self.model_chart.barh(labels, values)
            self.model_chart.set_title(f"{method} Allocation")
            self.model_chart.set_xlabel("Amount ($)")
            self.model_chart.invert_yaxis()
            max_val = max(values) if values else 0
            pad = max(max_val * 0.02, 1)
            for bar, value in zip(bars, values):
                self.model_chart.text(bar.get_width() + pad, bar.get_y() + bar.get_height()/2, f"${value:.2f}", va="center")

        self.model_figure.tight_layout()
        self.model_canvas.draw()

    def update_comparison_chart(self, month_key):
        self.compare_chart.clear()
        method = self.method_var.get()
        actual = self.db.get_expense_totals_by_category(month_key)

        if method == "Zero-Based":
            planned = self.db.get_allocations(month_key)
            categories = sorted(set(planned.keys()) | set(actual.keys()))
            if not categories:
                self.compare_chart.set_title("Planned vs Actual")
                self.compare_chart.text(0.5, 0.5, "No plan or expense data yet", ha="center", va="center")
            else:
                y = list(range(len(categories)))
                planned_vals = [planned.get(cat, 0.0) for cat in categories]
                actual_vals = [actual.get(cat, 0.0) for cat in categories]
                height = 0.35
                self.compare_chart.barh([i - height/2 for i in y], planned_vals, height=height, label="Planned")
                self.compare_chart.barh([i + height/2 for i in y], actual_vals, height=height, label="Actual")
                self.compare_chart.set_yticks(y)
                self.compare_chart.set_yticklabels(categories)
                self.compare_chart.set_title("Zero-Based Planned vs Actual")
                self.compare_chart.set_xlabel("Amount ($)")
                self.compare_chart.legend()
        else:
            if not actual:
                self.compare_chart.set_title("Expense Categories")
                self.compare_chart.text(0.5, 0.5, "No expense data yet", ha="center", va="center")
            else:
                categories = list(actual.keys())
                values = list(actual.values())
                bars = self.compare_chart.bar(categories, values)
                self.compare_chart.set_title("Actual Expense Categories")
                self.compare_chart.set_xlabel("Category")
                self.compare_chart.set_ylabel("Amount ($)")
                self.compare_chart.tick_params(axis="x", rotation=25)
                for bar, value in zip(bars, values):
                    self.compare_chart.text(bar.get_x() + bar.get_width()/2, bar.get_height(), f"${value:.0f}", ha="center", va="bottom")

        self.compare_figure.tight_layout()
        self.compare_canvas.draw()

    def refresh_all(self):
        month_key = self.validate_month_key()
        if not month_key:
            return
        self.method_var.set(self.db.get_setting("budget_method", self.method_var.get()))
        self.income_var.set(self.db.get_setting("monthly_income", self.income_var.get()))
        self.custom_percent_var.set(self.db.get_setting("custom_savings_percent", self.custom_percent_var.get()))
        self.refresh_categories()
        self.update_custom_visibility()
        self.update_summary(month_key)
        self.update_transactions_table(month_key)
        self.update_model_chart(month_key)
        self.update_comparison_chart(month_key)


if __name__ == "__main__":
    root = tk.Tk()
    app = BudgetTrackerApp(root)
    root.mainloop()
